# Set MODE=text to enable text input mode (useful for testing tools)
# Leave unset or empty for voice mode (default)
MODE=

# Tavily API key for web_search tool. Get a free one (1000 searches/month)
# at https://tavily.com. Without this, web_search returns an error.
TAVILY_API_KEY=

# Set WAKE_WORD=1 to enable continuous wake-word listening for "Electron".
# Requires models/ggml-tiny.en.bin to exist. Costs ~5% CPU continuously.
WAKE_WORD=
